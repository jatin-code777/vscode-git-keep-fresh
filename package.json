{
  "name": "git-keep-fresh",
  "displayName": "Git Keep Fresh",
  "description": "Keeps your local branches fresh by quietly pulling from origin in the background, so you never have a stale master again",
  "version": "0.1.1",
  "publisher": "thephotonforge",
  "author": {
    "name": "Jatin Sharma"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jatin-code777/vscode-git-keep-fresh"
  },
  "homepage": "https://github.com/jatin-code777/vscode-git-keep-fresh#readme",
  "bugs": {
    "url": "https://github.com/jatin-code777/vscode-git-keep-fresh/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#74d1fd",
    "theme": "dark"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "qna": "marketplace",
  "keywords": [
    "git",
    "pull",
    "auto",
    "sync",
    "branch",
    "fetch",
    "keep fresh",
    "background"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitKeepFresh.start",
        "title": "Git Keep Fresh: Start"
      },
      {
        "command": "gitKeepFresh.stop",
        "title": "Git Keep Fresh: Stop"
      },
      {
        "command": "gitKeepFresh.pullNow",
        "title": "Git Keep Fresh: Pull Now"
      },
      {
        "command": "gitKeepFresh.addBranch",
        "title": "Git Keep Fresh: Add Branch"
      },
      {
        "command": "gitKeepFresh.removeBranch",
        "title": "Git Keep Fresh: Remove Branch"
      }
    ],
    "configuration": {
      "title": "Git Keep Fresh",
      "properties": {
        "gitKeepFresh.branches": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "master"
          ],
          "description": "List of branch names to keep fresh from origin"
        },
        "gitKeepFresh.intervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Interval in minutes between pull cycles"
        },
        "gitKeepFresh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether Git Keep Fresh starts automatically when a workspace with a Git repository is opened"
        },
        "gitKeepFresh.pullCurrentBranch": {
          "type": "boolean",
          "default": false,
          "description": "If true, also pulls the currently checked-out branch (using git pull --ff-only). Only works when the working tree is clean."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
